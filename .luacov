-- .luacov
-- Coverage is measured on the amalgamated artifact dist/paypal-pos.lua because
-- specs dofile() that file directly. The src/ glob is retained for the day
-- specs are refactored to load individual modules.
--
-- IMPORTANT: luacov strips the ".lua" suffix before matching include/exclude
-- patterns, so patterns must not include "%.lua$" themselves. Two earlier
-- versions of this file used "src/.+%.lua$" and silently matched nothing —
-- the symptom was a zero-byte luacov.stats.out (logged as KI-01, now closed).
include = { "^src/", "^dist/paypal%-pos$" }
exclude = { "^src/webbanking_header$" }
threshold = 85
