-- .luacov
-- KNOWN ISSUE (Phase 6 follow-up): luacov 0.17.0 + busted 2.3.0 on Lua 5.4
-- does not produce non-empty stats with our current spec layout (specs load
-- the amalgamated dist/paypal-pos.lua via dofile rather than individual src/
-- modules). Strict threshold is deferred to Phase 6 when CI is hardened.
-- Tracked in .planning/phases/01-foundations-sandbox-probes/KNOWN_ISSUES.md
include = { "src/.+%.lua$", "dist/paypal%-pos%.lua$" }
exclude = { "src/webbanking_header%.lua$" }
threshold = 0
